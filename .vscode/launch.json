{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Inbix.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/src/Inbix.Web/bin/Debug/net10.0/Inbix.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Inbix.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5080"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "console": "internalConsole"
    },
    {
      "name": "Attach to process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
