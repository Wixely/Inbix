<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Repo-local source config. All Inbix dependencies are public packages from nuget.org.
       Sources are cleared so central package management restores deterministically and does
       not fall back to other machine-level feeds. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
