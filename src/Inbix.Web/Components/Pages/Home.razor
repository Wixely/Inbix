@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject IMessageRepository Messages
@inject NavigationManager Nav

<div class="page-head"><h1>Recent mail</h1></div>
<p class="muted page-note">
    The 10 latest messages across all mailboxes.
    @if (_userInteracted)
    {
        <span>Auto-refresh paused while you read.</span>
    }
    else
    {
        <span>Auto-refreshing every 20s — newest opens automatically.</span>
    }
</p>

<MailWindow>
    <Title>
        @if (_selected is not null)
        {
            <button class="tlabel-link" @onclick="OpenInMailbox" title="Open @_selected.MailboxLabel inbox">@_selected.MailboxLabel ↗</button>
        }
        else
        {
            <span class="tlabel">INBIX</span>
        }
    </Title>
    <List>
        @if (_recent is null)
        {
            <p class="muted pad">Loading…</p>
        }
        else if (_recent.Count == 0)
        {
            <p class="muted pad">No mail received yet.</p>
        }
        else
        {
            @foreach (var m in _recent)
            {
                <MailCard Sender="@m.Sender" Subject="@m.Subject" ReceivedAt="@m.ReceivedAt" Parsed="@m.Parsed"
                          Chip="@m.MailboxLabel" ChipColor="@m.AliasColor" Active="@(m.Id == _selectedId)" OnClick="@(() => SelectManual(m.Id))" />
            }
        }
    </List>
    <Preview>
        @if (_selected is null)
        {
            <div class="preview-empty muted">@(_recent is { Count: > 0 } ? "Select a message." : "Waiting for mail…")</div>
        }
        else
        {
            <div class="dash-pane-head">
                <h2 class="msg-subject">@(string.IsNullOrWhiteSpace(_selected.Subject) ? "(no subject)" : _selected.Subject)</h2>
                <button class="btn btn-primary dash-open" @onclick="OpenInMailbox" title="Open in @_selected.MailboxLabel">
                    Open
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6" /><path d="M10 14 21 3" /><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /></svg>
                </button>
            </div>
            <div class="dash-pane-scroll">
                <div class="kv"><span>From</span><span>@(_selected.Sender ?? "—")</span></div>
                <div class="kv"><span>To</span><span>@_selected.Recipient</span></div>
                <div class="kv"><span>Mailbox</span><span>@_selected.MailboxLabel</span></div>
                <div class="kv"><span>Received</span><span>@_selected.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>

                <pre class="text-view dash-text"><LinkifiedText Text="@_selectedText" Empty="@(_selected.Parsed ? "(no text body)" : "(parsing…)")" /></pre>
            </div>
        }
    </Preview>
</MailWindow>

@code {
    private static readonly TimeSpan RefreshInterval = TimeSpan.FromSeconds(20);

    private IReadOnlyList<RecentMessage>? _recent;
    private RecentMessage? _selected;
    private string? _selectedText;
    private long? _selectedId;
    private bool _userInteracted;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _timer = new System.Threading.Timer(_ => _ = TickAsync(), null, RefreshInterval, RefreshInterval);
    }

    private async Task TickAsync()
    {
        if (_userInteracted) return;
        try
        {
            await InvokeAsync(async () =>
            {
                await RefreshAsync();
                StateHasChanged();
            });
        }
        catch { /* ignore transient refresh errors */ }
    }

    private async Task RefreshAsync()
    {
        _recent = await Messages.ListRecentAsync(10);
        if (!_userInteracted)
            _selectedId = _recent.FirstOrDefault()?.Id; // newest open by default
        await LoadSelectedAsync();
    }

    private async Task LoadSelectedAsync()
    {
        _selected = _recent?.FirstOrDefault(m => m.Id == _selectedId);
        _selectedText = _selected is null ? null : (await Messages.GetBodyAsync(_selected.Id))?.TextBody;
    }

    private async Task SelectManual(long id)
    {
        _userInteracted = true;       // stop auto-refresh/auto-select once the user picks a message
        _timer?.Dispose();
        _timer = null;
        _selectedId = id;
        await LoadSelectedAsync();
    }

    private void OpenInMailbox()
    {
        if (_selected is not null)
            Nav.NavigateTo($"aliases/{_selected.AliasId}/inbox?m={_selected.Id}");
    }

    public void Dispose() => _timer?.Dispose();
}
