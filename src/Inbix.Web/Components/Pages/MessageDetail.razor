@page "/messages/{MessageId:long}"
@rendermode InteractiveServer
@inject IMessageRepository Messages

<p class="muted">
    @if (_aliasId is not null)
    {
        <a href="@($"aliases/{_aliasId}/inbox")">← Inbox</a>
    }
    else
    {
        <a href="aliases">← Aliases</a>
    }
</p>

<div class="panel msg-standalone">
    <MessageView MessageId="@MessageId" />
</div>

@code {
    [Parameter] public long MessageId { get; set; }

    private long? _aliasId;

    protected override async Task OnParametersSetAsync()
    {
        var message = await Messages.GetByIdAsync(MessageId);
        _aliasId = message?.AliasId;
    }
}
