@page "/messages/{MessageId:long}"
@rendermode InteractiveServer
@inject IMessageRepository Messages

<h1>Message</h1>

@if (_message is null)
{
    <p>@(_loaded ? "Message not found." : "Loading…")</p>
}
else
{
    <p class="muted"><a href="@($"aliases/{_message.AliasId}/inbox")">← Inbox</a></p>

    <div class="panel">
        <div class="kv"><span>Subject</span><strong>@(string.IsNullOrWhiteSpace(_message.Subject) ? "(no subject)" : _message.Subject)</strong></div>
        <div class="kv"><span>From</span><span>@(_message.Sender ?? "—")</span></div>
        <div class="kv"><span>To</span><span>@_message.Recipient</span></div>
        <div class="kv"><span>Received</span><span>@_message.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>
        <div class="kv"><span>Raw</span><a href="@($"api/messages/{_message.Id}/raw")" target="_blank">download .eml</a></div>
        @if (_message.ParseError is not null)
        {
            <div class="kv"><span>Parse error</span><span class="error">@_message.ParseError</span></div>
        }
    </div>

    @if (_attachments is { Count: > 0 })
    {
        <div class="panel">
            <h2>Attachments</h2>
            <ul>
                @foreach (var a in _attachments)
                {
                    <li>
                        <a href="@($"api/attachments/{a.Id}/content")" target="_blank">@(a.Filename ?? $"attachment-{a.Id}")</a>
                        <span class="muted">(@(a.ContentType ?? "?"), @(a.SizeBytes?.ToString() ?? "?") bytes)</span>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="panel">
        <div class="tabs">
            <button class="tab @(_showHtml ? "" : "active")" @onclick="() => _showHtml = false">Text</button>
            @if (!string.IsNullOrEmpty(_body?.HtmlBody))
            {
                <button class="tab @(_showHtml ? "active" : "")" @onclick="() => _showHtml = true">HTML</button>
            }
        </div>

        @if (_showHtml && !string.IsNullOrEmpty(_body?.HtmlBody))
        {
            @* Render untrusted HTML inside a sandboxed iframe to prevent script execution / XSS. *@
            <iframe class="html-view" sandbox="" srcdoc="@_body!.HtmlBody"></iframe>
        }
        else
        {
            <pre class="text-view">@(_body?.TextBody ?? "(no text body)")</pre>
        }
    </div>
}

@code {
    [Parameter] public long MessageId { get; set; }

    private Message? _message;
    private MessageBody? _body;
    private IReadOnlyList<Attachment>? _attachments;
    private bool _loaded;
    private bool _showHtml;

    protected override async Task OnInitializedAsync()
    {
        _message = await Messages.GetByIdAsync(MessageId);
        if (_message is not null)
        {
            _body = await Messages.GetBodyAsync(MessageId);
            _attachments = await Messages.ListAttachmentsAsync(MessageId);
        }
        _loaded = true;
    }
}
