@page "/aliases"
@rendermode InteractiveServer
@inject IAliasRepository AliasRepo
@inject IAliasService AliasService
@inject IBlacklistService Blacklist
@inject IAuditRepository Audit
@inject IOptions<InbixOptions> Options
@inject AliasChangeNotifier Notifier
@inject IIdentityRepository IdentityRepo

<div class="page-head">
    <h1>Aliases</h1>
    <button class="btn btn-primary" @onclick="OpenCreate" disabled="@_creating">+ New alias</button>
</div>

<p class="muted page-note">
    Changes show here immediately, but incoming-mail acceptance is cached and can take up to
    ~30&nbsp;seconds to take effect — including enabling or disabling the catch-all.
</p>

@if (_flash is not null)
{
    <p class="flash">@_flash</p>
}

@if (_aliases is null)
{
    <p>Loading…</p>
}
else
{
    <table class="grid">
        <thead>
            <tr><th>Address</th><th>Status</th><th>Created</th><th>Notes</th><th>Expiry</th><th>Shortname</th><th class="actions-col"></th></tr>
        </thead>
        <tbody>
            @if (_creating)
            {
                @EditorRow
            }

            @if (CatchAll is { } ca)
            {
                <tr class="catchall-row">
                    <td>
                        @ColorPicker(ca)<a href="@($"aliases/{ca.Id}/inbox")">Catch-all</a>
                        <div class="muted catchall-hint">Stores mail for any address on your domains</div>
                    </td>
                    <td>
                        <label class="switch" title="@(ca.Enabled ? "Click to disable" : "Click to enable")">
                            <input type="checkbox" checked="@ca.Enabled" @onchange="() => ToggleAsync(ca)" />
                            <span class="slider"></span>
                            <span class="switch-label">@(ca.Enabled ? "Enabled" : "Disabled")</span>
                        </label>
                    </td>
                    <td class="muted">—</td>
                    <td class="muted">@ca.Notes</td>
                    <td>@ExpiryCell(ca)</td>
                    <td class="muted">—</td>
                    <td class="row-actions"></td>
                </tr>
            }

            @foreach (var a in Regular)
            {
                @if (_editingId == a.Id)
                {
                    @EditorRow
                }
                else
                {
                    <tr>
                        <td>@ColorPicker(a)<a href="@($"aliases/{a.Id}/inbox")">@a.Address</a>@IdentityChip(a)</td>
                        <td>
                            <label class="switch" title="@(a.Enabled ? "Click to disable" : "Click to enable")">
                                <input type="checkbox" checked="@a.Enabled" @onchange="() => ToggleAsync(a)" />
                                <span class="slider"></span>
                                <span class="switch-label">@(a.Enabled ? "Enabled" : "Disabled")</span>
                            </label>
                        </td>
                        <td>@a.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="muted">@a.Notes</td>
                        <td>@ExpiryCell(a)</td>
                        <td>@ShortnameCell(a)</td>
                        <td class="row-actions">
                            @if (_confirmingDeleteId == a.Id)
                            {
                                <span class="muted" title="Its mail moves to the catch-all.">Delete?</span>
                                <label class="block-on-delete muted" title="Add a junk rule for this address so future mail to it is filtered out of the catch-all.">
                                    <input type="checkbox" @bind="_blockOnDelete" /> block
                                </label>
                                <button class="btn-link danger" @onclick="() => DeleteAsync(a)" disabled="@_busy">Yes</button>
                                <button class="btn-link" @onclick="() => CancelDelete()" disabled="@_busy">No</button>
                            }
                            else
                            {
                                <button class="btn-link" @onclick="() => OpenEdit(a)">Edit</button>
                                <button class="btn-link danger" @onclick="() => _confirmingDeleteId = a.Id">Delete</button>
                            }
                        </td>
                    </tr>
                }
            }

            @if (!Regular.Any() && !_creating)
            {
                <tr><td colspan="7" class="muted empty-row">No aliases yet — click “New alias” to add one.</td></tr>
            }
        </tbody>
    </table>

    @if (_expiryPreview is not null && _expiryAlias is { } xa)
    {
        <div class="panel sweep-preview">
            <div class="sweep-preview-head">
                <h2>Enable expiry</h2>
                <button class="btn-ghost" @onclick="CancelExpiryPreview" disabled="@_busy">Close</button>
            </div>
            <p class="muted">
                Enabling <strong>@_expiryDaysConfirm-day</strong> expiry on <strong>@LabelText(xa)</strong> will
                permanently delete <strong>@_expiryPreview.Count</strong> message(s)@(_expiryPreview.Count > _expiryPreview.Sample.Count ? $" (showing the oldest {_expiryPreview.Sample.Count})" : "").
            </p>
            <div class="sweep-cards">
                @foreach (var m in _expiryPreview.Sample)
                {
                    <a class="sweep-card" href="@($"aliases/{m.AliasId}/inbox?m={m.Id}")" target="_blank">
                        <div class="sweep-card-from">@(string.IsNullOrWhiteSpace(m.Sender) ? "(unknown sender)" : m.Sender)</div>
                        <div class="sweep-card-subj">@(string.IsNullOrWhiteSpace(m.Subject) ? "(no subject)" : m.Subject)</div>
                        <div class="sweep-card-meta">@m.Recipient <span class="when-sep">&middot;</span> @TimeFormat.Timestamp(m.ReceivedAt)</div>
                    </a>
                }
            </div>
            <div class="btn-row">
                <button class="btn btn-primary" @onclick="ConfirmExpiryAsync" disabled="@_busy">Enable &amp; delete @_expiryPreview.Count now</button>
                <button class="btn-ghost" @onclick="CancelExpiryPreview" disabled="@_busy">Cancel</button>
            </div>
        </div>
    }
}

@code {
    // Quick-alias deep link from the catch-all inbox: pre-fill and open the create form.
    [SupplyParameterFromQuery(Name = "new")] public string? PrefillAddress { get; set; }
    [SupplyParameterFromQuery(Name = "notes")] public string? PrefillNotes { get; set; }

    private IReadOnlyList<Alias>? _aliases;
    private Dictionary<long, Identity> _identitiesByAlias = [];
    private List<string> _domains = [];

    private bool _creating;
    private long? _editingId;
    private long? _confirmingDeleteId;
    private bool _blockOnDelete;
    private long? _pickerForId;

    // Per-mailbox expiry editor + warning panel state.
    private long? _expiryForId;
    private bool _expiryEnabledForm;
    private int _expiryDaysForm = 60;
    private SweepPreview? _expiryPreview;
    private Alias? _expiryAlias;
    private int _expiryDaysConfirm = 60;

    // Shortname (display name) editor state.
    private long? _shortnameForId;
    private bool _shortnameEnabledForm;
    private string _shortnameForm = string.Empty;

    // 24-colour accent palette; the first entry (violet) is the default applied to new aliases.
    private static readonly string[] Palette =
    [
        "#8b7cf6", "#6c5ce7", "#5b8def", "#3aa0ff", "#00b8d4", "#2dd4a7",
        "#26c281", "#4cd137", "#a3cb38", "#f5b73d", "#f0932b", "#f06860",
        "#eb4d4b", "#e84393", "#fd79a8", "#c56cf0", "#9b59b6", "#7f8fa6",
        "#b2bec3", "#ff7675", "#ffd56b", "#55efc4", "#74b9ff", "#dfe6e9"
    ];
    private string _formLocalPart = string.Empty;
    private string _formDomain = string.Empty;
    private string _formNotes = string.Empty;
    private string? _error;
    private string? _flash;
    private bool _busy;

    private string FormAddress => $"{_formLocalPart}@{_formDomain}";

    private Alias? CatchAll => _aliases?.FirstOrDefault(a => a.IsCatchAll);
    private IEnumerable<Alias> Regular => _aliases?.Where(a => !a.IsCatchAll) ?? [];

    // Shared inline editor used for both create (blank row at the top) and edit (in place of the row).
    private RenderFragment EditorRow => @<tr class="edit-row">
        <td colspan="7">
            <div class="form-row">
                @if (_editingId is null)
                {
                    <input class="input" placeholder="local part (e.g. spotify)" @bind="_formLocalPart" />
                    <span class="at">@@</span>
                    @if (_domains.Count > 1)
                    {
                        <select class="input" @bind="_formDomain">
                            @foreach (var d in _domains)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    }
                    else
                    {
                        <span class="at">@_formDomain</span>
                    }
                }
                else
                {
                    <span class="readonly-address" title="Aliases are permanent and can't be renamed.">@FormAddress</span>
                }
                <input class="input grow" placeholder="notes (optional)" @bind="_formNotes" />
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_editingId is null ? "Create" : "Save")</button>
                <button class="btn-ghost" @onclick="Cancel" disabled="@_busy">Cancel</button>
            </div>
            @if (_error is not null)
            {
                <p class="error inline-error">@_error</p>
            }
        </td>
    </tr>;

    // Colour swatch + popover palette, shared by the catch-all and regular alias rows.
    private RenderFragment ColorPicker(Alias a) => @<span class="color-cell">
        <button type="button" class="color-swatch" style="background:@a.Color"
                title="Change colour" @onclick="() => TogglePicker(a.Id)"></button>
        @if (_pickerForId == a.Id)
        {
            <div class="color-popover">
                @foreach (var c in Palette)
                {
                    <button type="button" title="@c" style="background:@c"
                            class="color-opt @(string.Equals(c, a.Color, StringComparison.OrdinalIgnoreCase) ? "sel" : "")"
                            @onclick="() => SetColorAsync(a, c)"></button>
                }
            </div>
        }
    </span>;

    // Small chip in the address cell linking to the saved identity for this alias, when one exists.
    private RenderFragment IdentityChip(Alias a) => @<span>
        @if (_identitiesByAlias.TryGetValue(a.Id, out var id))
        {
            <a class="id-chip" href="identities" title="@($"Linked identity: {id.FullName}")">@id.FullName</a>
        }
    </span>;

    private void TogglePicker(long id)
    {
        _expiryForId = null;
        _shortnameForId = null;
        _pickerForId = _pickerForId == id ? null : id;
    }

    // Per-mailbox expiry chip + popover editor, shared by the catch-all and regular alias rows.
    private RenderFragment ExpiryCell(Alias a) => @<span class="color-cell">
        <button type="button" class="expiry-chip @(a.ExpiryEnabled ? "on" : "")"
                title="Message expiry" @onclick="() => OpenExpiry(a)">
            @(a.ExpiryEnabled ? $"{a.ExpiryDays}d" : "Off")
        </button>
        @if (_expiryForId == a.Id)
        {
            <div class="color-popover expiry-popover">
                <label class="switch">
                    <input type="checkbox" @bind="_expiryEnabledForm" />
                    <span class="slider"></span>
                    <span class="switch-label">Auto-delete old mail</span>
                </label>
                <div class="expiry-days">
                    after <input class="input expiry-days-input" type="number" min="1" @bind="_expiryDaysForm" /> days
                </div>
                <div class="expiry-actions">
                    <button class="btn btn-primary" @onclick="() => ApplyExpiryAsync(a)" disabled="@_busy">Apply</button>
                    <button class="btn-ghost" @onclick="CancelExpiry" disabled="@_busy">Cancel</button>
                </div>
            </div>
        }
    </span>;

    private void OpenExpiry(Alias a)
    {
        _pickerForId = null;
        _shortnameForId = null;
        CancelExpiryPreview();
        _expiryForId = a.Id;
        _expiryEnabledForm = a.ExpiryEnabled;
        _expiryDaysForm = a.ExpiryDays;
    }

    // Shortname (display name) chip + popover editor.
    private RenderFragment ShortnameCell(Alias a) => @<span class="color-cell">
        <button type="button" class="expiry-chip @(a.ShortnameEnabled && !string.IsNullOrWhiteSpace(a.Shortname) ? "on" : "")"
                title="Display name" @onclick="() => OpenShortname(a)">
            @(a.ShortnameEnabled && !string.IsNullOrWhiteSpace(a.Shortname) ? a.Shortname : "Off")
        </button>
        @if (_shortnameForId == a.Id)
        {
            <div class="color-popover expiry-popover">
                <label class="switch">
                    <input type="checkbox" @bind="_shortnameEnabledForm" />
                    <span class="slider"></span>
                    <span class="switch-label">Show shortname</span>
                </label>
                <input class="input shortname-input" placeholder="display name" @bind="_shortnameForm" />
                <div class="expiry-actions">
                    <button class="btn btn-primary" @onclick="() => ApplyShortnameAsync(a)" disabled="@_busy">Apply</button>
                    <button class="btn-ghost" @onclick="CancelShortname" disabled="@_busy">Cancel</button>
                </div>
            </div>
        }
    </span>;

    private void OpenShortname(Alias a)
    {
        _pickerForId = null;
        _expiryForId = null;
        CancelExpiryPreview();
        _shortnameForId = a.Id;
        _shortnameEnabledForm = a.ShortnameEnabled;
        // Auto-fill from the local part when no shortname has been set yet (e.g. spotify@host -> "spotify").
        _shortnameForm = string.IsNullOrWhiteSpace(a.Shortname) ? a.LocalPart : a.Shortname;
    }

    private void CancelShortname() => _shortnameForId = null;

    private async Task ApplyShortnameAsync(Alias a)
    {
        _shortnameForId = null;
        var name = _shortnameForm.Trim();
        var enabled = _shortnameEnabledForm && name.Length > 0;
        await AliasRepo.UpdateShortnameAsync(a.Id, enabled, name);
        await Audit.WriteAsync(new AuditEntry { Action = "alias.shortname", TargetType = "alias", TargetId = a.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
        _flash = enabled ? $"{a.Address} now shows as \"{name}\"." : $"Shortname disabled for {a.Address}.";
        await ReloadAsync();
        Notifier.NotifyChanged();
    }

    private void CancelExpiry() => _expiryForId = null;

    private void CancelExpiryPreview()
    {
        _expiryPreview = null;
        _expiryAlias = null;
    }

    private static string LabelText(Alias a) => a.IsCatchAll ? "the catch-all" : a.Address;

    private async Task ApplyExpiryAsync(Alias a)
    {
        var days = Math.Max(1, _expiryDaysForm);
        _expiryForId = null;

        if (!_expiryEnabledForm)
        {
            await AliasService.SetExpiryAsync(a.Id, false, days, deleteNow: false);
            await AuditExpiryAsync(a.Id);
            _flash = $"Expiry disabled for {LabelText(a)}.";
            await ReloadAsync();
            return;
        }

        var preview = await AliasService.ExpiryPreviewAsync(a.Id, days);
        if (preview.Count == 0)
        {
            await AliasService.SetExpiryAsync(a.Id, true, days, deleteNow: false);
            await AuditExpiryAsync(a.Id);
            _flash = $"Enabled {days}-day expiry for {LabelText(a)} (no mail is old enough to delete yet).";
            await ReloadAsync();
            return;
        }

        // Old mail exists — warn with a preview before deleting anything.
        _expiryPreview = preview;
        _expiryAlias = a;
        _expiryDaysConfirm = days;
    }

    private async Task ConfirmExpiryAsync()
    {
        if (_expiryAlias is not { } a) return;
        _busy = true;
        try
        {
            var deleted = await AliasService.SetExpiryAsync(a.Id, true, _expiryDaysConfirm, deleteNow: true);
            await AuditExpiryAsync(a.Id);
            _flash = $"Enabled {_expiryDaysConfirm}-day expiry for {LabelText(a)}; deleted {deleted} old message(s).";
            CancelExpiryPreview();
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private Task AuditExpiryAsync(long aliasId) =>
        Audit.WriteAsync(new AuditEntry { Action = "alias.expiry", TargetType = "alias", TargetId = aliasId.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });

    private async Task SetColorAsync(Alias a, string color)
    {
        _pickerForId = null;
        if (string.Equals(a.Color, color, StringComparison.OrdinalIgnoreCase))
            return;
        await AliasRepo.UpdateColorAsync(a.Id, color);
        await Audit.WriteAsync(new AuditEntry { Action = "alias.color", TargetType = "alias", TargetId = a.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
        await ReloadAsync();
        Notifier.NotifyChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        _domains = Options.Value.Domains
            .Where(d => !string.IsNullOrWhiteSpace(d))
            .Select(d => d.Trim().ToLowerInvariant())
            .ToList();
        await ReloadAsync();

        if (!string.IsNullOrWhiteSpace(PrefillAddress))
            PrefillCreateForm(PrefillAddress, PrefillNotes);
    }

    // Opens the create editor pre-filled from a "?new=address&notes=..." deep link.
    private void PrefillCreateForm(string address, string? notes)
    {
        OpenCreate();
        var at = address.IndexOf('@');
        if (at > 0)
        {
            _formLocalPart = address[..at];
            var domain = address[(at + 1)..].Trim().ToLowerInvariant();
            if (_domains.Contains(domain)) _formDomain = domain;
        }
        else
        {
            _formLocalPart = address.Trim();
        }
        if (!string.IsNullOrWhiteSpace(notes)) _formNotes = notes;
    }

    private async Task ReloadAsync()
    {
        _aliases = await AliasRepo.ListAsync();
        _identitiesByAlias = (await IdentityRepo.ListAsync())
            .Where(i => i.AliasId is not null)
            .ToDictionary(i => i.AliasId!.Value);
    }

    private void OpenCreate()
    {
        _editingId = null;
        _creating = true;
        _formLocalPart = string.Empty;
        _formDomain = _domains.FirstOrDefault() ?? string.Empty;
        _formNotes = string.Empty;
        _error = null;
    }

    private void OpenEdit(Alias a)
    {
        _creating = false;
        _editingId = a.Id;
        _formLocalPart = a.LocalPart;
        _formDomain = a.Domain;
        _formNotes = a.Notes ?? string.Empty;
        _error = null;
    }

    private void Cancel()
    {
        _creating = false;
        _editingId = null;
        _error = null;
    }

    private async Task SaveAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            if (_editingId is null)
            {
                var error = Inbix.Core.Validation.AliasRules.ValidateLocalPart(_formLocalPart);
                if (error is not null) { _error = error; return; }
                if (string.IsNullOrWhiteSpace(_formDomain)) { _error = "No domain configured (set Inbix:Domains)."; return; }

                var localPart = Inbix.Core.Validation.AliasRules.Normalize(_formLocalPart);
                var (created, migrated) = await AliasService.CreateAsync(localPart, _formDomain, string.IsNullOrWhiteSpace(_formNotes) ? null : _formNotes);
                await Audit.WriteAsync(new AuditEntry { Action = "alias.create", TargetType = "alias", TargetId = created.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
                _flash = migrated > 0
                    ? $"Created {created.Address} and moved {migrated} existing message(s) from the catch-all into it."
                    : $"Created {created.Address}.";
            }
            else
            {
                // Pass the raw value (empty string clears the note); enabled stays unchanged.
                await AliasRepo.UpdateAsync(_editingId.Value, enabled: null, notes: _formNotes);
                await Audit.WriteAsync(new AuditEntry { Action = "alias.update", TargetType = "alias", TargetId = _editingId.Value.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
            }

            Cancel();
            await ReloadAsync();
            Notifier.NotifyChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message.Contains("UNIQUE", StringComparison.OrdinalIgnoreCase)
                ? "That alias already exists."
                : ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task ToggleAsync(Alias a)
    {
        await AliasRepo.UpdateAsync(a.Id, enabled: !a.Enabled, notes: null);
        await Audit.WriteAsync(new AuditEntry { Action = a.Enabled ? "alias.disable" : "alias.enable", TargetType = "alias", TargetId = a.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
        await ReloadAsync();
        Notifier.NotifyChanged();
    }

    private void CancelDelete()
    {
        _confirmingDeleteId = null;
        _blockOnDelete = false;
    }

    private async Task DeleteAsync(Alias a)
    {
        _busy = true;
        try
        {
            var moved = await AliasService.DeleteAsync(a.Id);
            await Audit.WriteAsync(new AuditEntry { Action = "alias.delete", TargetType = "alias", TargetId = a.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });

            var blocked = _blockOnDelete;
            if (blocked)
            {
                await Blacklist.CreateAsync(new BlacklistRule
                {
                    Name = $"Blocked {a.Address}",
                    Target = RuleTarget.Recipient,
                    MatchType = RuleMatch.Literal,
                    Pattern = a.Address,
                    Action = RuleAction.Junk,
                    Enabled = true
                });
            }

            _confirmingDeleteId = null;
            _blockOnDelete = false;
            var movedNote = moved > 0 ? $" and moved {moved} message(s) to the catch-all" : "";
            _flash = blocked
                ? $"Deleted {a.Address}{movedNote}; future mail to it will be junked."
                : $"Deleted {a.Address}{movedNote}.";
            await ReloadAsync();
            Notifier.NotifyChanged();
        }
        finally { _busy = false; }
    }
}
