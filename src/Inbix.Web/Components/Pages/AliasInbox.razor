@page "/aliases/{AliasId:long}/inbox"
@rendermode InteractiveServer
@inject IAliasRepository AliasRepo
@inject IMessageRepository Messages

@if (_alias is null)
{
    <p>@(_loaded ? "Inbox not found." : "Loading…")</p>
}
else
{
    <div class="page-head"><h1>@Title</h1></div>
    <p class="muted page-note"><a href="aliases">← Aliases</a></p>

    <MailWindow>
        <Title><span class="tlabel">@Title</span></Title>
        <List>
            @if (_items is null)
            {
                <p class="muted pad">Loading…</p>
            }
            else if (_items.Count == 0)
            {
                <p class="muted pad">No messages received for this inbox yet.</p>
            }
            else
            {
                @foreach (var m in _items)
                {
                    <MailCard Sender="@m.Sender" Subject="@m.Subject" ReceivedAt="@m.ReceivedAt" Parsed="@m.Parsed"
                              Chip="@(_alias.IsCatchAll ? m.Recipient : null)" Active="@(m.Id == _selectedId)"
                              OnClick="@(() => _selectedId = m.Id)" />
                }
            }
        </List>
        <Preview>
            @if (_selectedId is null)
            {
                <div class="preview-empty muted">Select a message to read it.</div>
            }
            else
            {
                <div class="msg-scroll">
                    <MessageView MessageId="@_selectedId.Value" />
                </div>
            }
        </Preview>
    </MailWindow>
}

@code {
    [Parameter] public long AliasId { get; set; }

    /// <summary>Optional message to preselect (e.g. when arriving from the dashboard's "Open in mailbox").</summary>
    [SupplyParameterFromQuery(Name = "m")] public long? PreselectId { get; set; }

    private Alias? _alias;
    private IReadOnlyList<InboxItem>? _items;
    private long? _selectedId;
    private bool _loaded;
    private long _loadedAliasId = -1;

    private string Title => _alias is null ? "" : _alias.IsCatchAll ? "Catch-all" : _alias.Address;

    protected override async Task OnParametersSetAsync()
    {
        if (AliasId != _loadedAliasId)
        {
            _loadedAliasId = AliasId;
            _selectedId = null;
            _alias = await AliasRepo.GetByIdAsync(AliasId);
            _items = _alias is null ? null : await Messages.ListByAliasWithPreviewAsync(AliasId, 100, 0);
            _loaded = true;
        }

        if (_items is { Count: > 0 })
        {
            // Preselect the message from ?m= if present, otherwise default to the newest.
            if (PreselectId is long pid && _items.Any(i => i.Id == pid))
                _selectedId = pid;
            else
                _selectedId ??= _items[0].Id;
        }
    }
}
