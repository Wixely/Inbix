@page "/aliases/{AliasId:long}/inbox"
@rendermode InteractiveServer
@inject IAliasRepository AliasRepo
@inject IMessageRepository Messages

@if (_alias is null)
{
    <p>@(_loaded ? "Inbox not found." : "Loading…")</p>
}
else
{
    <div class="page-head">
        <h1>@Title</h1>
    </div>
    <p class="muted page-note"><a href="aliases">← Aliases</a></p>

    <div class="mailbox">
        <div class="mail-list">
            @if (_items is null)
            {
                <p class="muted pad">Loading…</p>
            }
            else if (_items.Count == 0)
            {
                <p class="muted pad">No messages received for this inbox yet.</p>
            }
            else
            {
                @foreach (var m in _items)
                {
                    <button type="button" class="mail-card @(m.Id == _selectedId ? "active" : "")" @onclick="() => _selectedId = m.Id">
                        <div class="mail-card-row">
                            <span class="mail-from">@(string.IsNullOrWhiteSpace(m.Sender) ? "(unknown sender)" : m.Sender)</span>
                            <span class="mail-time">@FormatTime(m.ReceivedAt)</span>
                        </div>
                        <div class="mail-subject">
                            @(string.IsNullOrWhiteSpace(m.Subject) ? "(no subject)" : m.Subject)
                            @if (!m.Parsed)
                            {
                                <span class="badge off">unparsed</span>
                            }
                        </div>
                        <div class="mail-snippet">
                            @if (_alias.IsCatchAll)
                            {
                                <span class="mail-to">@m.Recipient</span>
                            }
                            @Clean(m.Snippet)
                        </div>
                    </button>
                }
            }
        </div>

        <div class="mail-preview">
            @if (_selectedId is null)
            {
                <div class="preview-empty muted">Select a message to read it.</div>
            }
            else
            {
                <MessageView MessageId="@_selectedId.Value" />
            }
        </div>
    </div>
}

@code {
    [Parameter] public long AliasId { get; set; }

    private Alias? _alias;
    private IReadOnlyList<InboxItem>? _items;
    private long? _selectedId;
    private bool _loaded;
    private long _loadedAliasId = -1;

    private string Title => _alias is null ? "" : _alias.IsCatchAll ? "Catch-all" : _alias.Address;

    protected override async Task OnParametersSetAsync()
    {
        if (AliasId == _loadedAliasId) return;
        _loadedAliasId = AliasId;
        _selectedId = null;

        _alias = await AliasRepo.GetByIdAsync(AliasId);
        if (_alias is not null)
        {
            _items = await Messages.ListByAliasWithPreviewAsync(AliasId, 100, 0);
            _selectedId = _items.FirstOrDefault()?.Id; // auto-open the newest, like a mail client
        }
        _loaded = true;
    }

    private static string FormatTime(DateTimeOffset t)
    {
        var local = t.ToLocalTime();
        return local.Date == DateTimeOffset.Now.Date ? local.ToString("HH:mm") : local.ToString("MMM d");
    }

    private static string Clean(string? snippet) =>
        string.IsNullOrWhiteSpace(snippet) ? "" : System.Text.RegularExpressions.Regex.Replace(snippet, "\\s+", " ").Trim();
}
