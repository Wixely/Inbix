@page "/audit"
@inject IAuditRepository AuditRepo

<h1>Audit log</h1>

@if (_entries is null)
{
    <p>Loading…</p>
}
else if (_entries.Count == 0)
{
    <p class="muted">No audit entries yet.</p>
}
else
{
    <table class="grid">
        <thead>
            <tr><th>When</th><th>Actor</th><th>Action</th><th>Target</th></tr>
        </thead>
        <tbody>
            @foreach (var e in _entries)
            {
                <tr>
                    <td>@e.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(e.Actor ?? "—")</td>
                    <td>@e.Action</td>
                    <td class="muted">@e.TargetType #@e.TargetId</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<AuditEntry>? _entries;

    protected override async Task OnInitializedAsync()
        => _entries = await AuditRepo.ListAsync(200, 0);
}
