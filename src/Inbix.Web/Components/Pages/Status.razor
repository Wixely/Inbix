@page "/status"
@rendermode InteractiveServer
@using Inbix.Core.Abstractions
@using Inbix.Core.Domain
@using Inbix.Web.Diagnostics
@inject DiagnosticsService Diagnostics
@inject IReloadableStore Store
@inject IRawReindexer Reindexer
@inject IAuditRepository Audit

<h1>Status</h1>
<p class="lead">Run configuration diagnostics to catch common inbound-mail misconfigurations — database,
storage, aliases, TLS, the SMTP listener, and DNS (public IP, MX records, MX→IP match, reverse DNS).</p>

<div class="btn-row">
    <button class="btn btn-primary" @onclick="RunAsync" disabled="@_running">
        @(_running ? "Running…" : (_results is null ? "Run diagnostics" : "Re-run"))
    </button>
    @if (Store.CanReload)
    {
        <button class="btn" @onclick="ReloadAsync" disabled="@(_running || _reloading)"
                title="Re-read the JSON store from disk into memory (no restart)">
            @(_reloading ? "Reloading…" : "Reload from disk")
        </button>
    }
    <button class="btn btn-ghost" @onclick="() => _confirmReindex = true" disabled="@(_reindexing || _confirmReindex)"
            title="Recover mail from the raw store when the index is missing entries">
        Re-index from raw
    </button>
    @if (_results is not null)
    {
        <span class="status-summary">
            <span class="st st-ok">@_results.Count(r => r.Status == DiagnosticStatus.Ok) OK</span>
            <span class="st st-warn">@_results.Count(r => r.Status == DiagnosticStatus.Warning) warnings</span>
            <span class="st st-err">@_results.Count(r => r.Status == DiagnosticStatus.Error) failures</span>
        </span>
    }
</div>

@if (_confirmReindex)
{
    <div class="panel">
        <h2>Re-index from raw storage?</h2>
        <p class="muted">
            This scans the raw message store and re-creates inbox entries for any emails that are missing
            from the index — for example after the database / JSON store was lost while the raw files
            survived. Messages already in your inbox are left untouched.
        </p>
        <p class="muted">
            <strong class="accent">Heads up:</strong> routing is best-effort. The mailbox and receive time are
            reconstructed from each message's headers, so recovered mail whose original alias can't be
            determined lands in the <strong>catch-all</strong>. A large store can take a while; recovered
            messages are re-parsed by the background worker and appear as they finish.
        </p>
        <div class="btn-row">
            <button class="btn" @onclick="ReindexAsync" disabled="@_reindexing">
                @(_reindexing ? "Re-indexing…" : "Yes, re-index")
            </button>
            <button class="btn btn-ghost" @onclick="() => _confirmReindex = false" disabled="@_reindexing">Cancel</button>
        </div>
    </div>
}

@if (_flash is not null)
{
    <p class="muted last-run">@_flash</p>
}

@if (_lastRun is not null)
{
    <p class="muted last-run">Last run @_lastRun.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") (@TimeFormat.Ago(_lastRun.Value))</p>
}
else
{
    <p class="muted last-run">Not run yet this session.</p>
}

@if (_running && _results is null)
{
    <p class="muted">Running checks (DNS lookups may take a few seconds)…</p>
}

@if (_results is not null)
{
    @foreach (var group in _results.GroupBy(r => r.Category))
    {
        <div class="panel">
            <h2>@group.Key</h2>
            <div class="table-wrap">
            <table class="grid">
                <tbody>
                    @foreach (var r in group)
                    {
                        <tr>
                            <td class="status-cell"><span class="st @CssFor(r.Status)">@LabelFor(r.Status)</span></td>
                            <td><strong>@r.Name</strong></td>
                            <td>
                                @r.Message
                                @if (!string.IsNullOrEmpty(r.Detail))
                                {
                                    <div class="muted status-detail">
                                        @if (r.Sensitive)
                                        {
                                            <RevealText Text="@r.Detail" CollapsedLabel="Show path" />
                                        }
                                        else
                                        {
                                            @r.Detail
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    }
}

@code {
    private IReadOnlyList<DiagnosticResult>? _results;
    private DateTimeOffset? _lastRun;
    private bool _running;
    private bool _reloading;
    private bool _reindexing;
    private bool _confirmReindex;
    private string? _flash;

    protected override void OnInitialized()
    {
        // Restore the most recent run so navigating away and back keeps the results.
        _results = Diagnostics.LastResults;
        _lastRun = Diagnostics.LastRunAtUtc;
    }

    private async Task RunAsync()
    {
        _running = true;
        try
        {
            _results = await Diagnostics.RunAllAsync();
            _lastRun = Diagnostics.LastRunAtUtc;
        }
        finally
        {
            _running = false;
        }
    }

    private async Task ReloadAsync()
    {
        _reloading = true;
        _flash = null;
        try
        {
            await Store.ReloadAsync();
            _flash = "Reloaded the store from disk.";
            _results = await Diagnostics.RunAllAsync();
            _lastRun = Diagnostics.LastRunAtUtc;
        }
        catch (Exception ex)
        {
            _flash = $"Reload failed: {ex.Message}";
        }
        finally
        {
            _reloading = false;
        }
    }

    private async Task ReindexAsync()
    {
        _reindexing = true;
        _flash = null;
        try
        {
            var r = await Reindexer.ReindexAsync();
            await Audit.WriteAsync(new AuditEntry
            {
                Action = "storage.reindex", TargetType = "storage", Actor = "ui",
                Details = $"recovered={r.Recovered} skipped={r.Skipped} failed={r.Failed}",
                CreatedAt = DateTimeOffset.UtcNow
            });
            _confirmReindex = false;
            _flash = $"Re-index complete: {r.Recovered} recovered, {r.Skipped} already present, {r.Failed} failed."
                   + (r.Recovered > 0 ? " Recovered messages will finish parsing shortly." : "");
        }
        catch (Exception ex)
        {
            _flash = $"Re-index failed: {ex.Message}";
        }
        finally
        {
            _reindexing = false;
        }
    }

    private static string CssFor(DiagnosticStatus s) => s switch
    {
        DiagnosticStatus.Ok => "st-ok",
        DiagnosticStatus.Warning => "st-warn",
        DiagnosticStatus.Error => "st-err",
        _ => "st-info"
    };

    private static string LabelFor(DiagnosticStatus s) => s switch
    {
        DiagnosticStatus.Ok => "OK",
        DiagnosticStatus.Warning => "WARN",
        DiagnosticStatus.Error => "FAIL",
        _ => "INFO"
    };
}
