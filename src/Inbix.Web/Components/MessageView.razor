@inject IMessageRepository Messages
@inject IBlacklistService Blacklist
@inject IAuditRepository Audit
@inject IRawMessageStore RawStore
@inject NavigationManager Nav
@implements IDisposable

@if (_message is null)
{
    <p class="muted">@(_loaded ? "Message not found." : "Loading…")</p>
}
else
{
    <div class="msg-head">
        <h2 class="msg-subject">@(string.IsNullOrWhiteSpace(_message.Subject) ? "(no subject)" : _message.Subject)</h2>
        <div class="kv"><span>From</span><span>@(_message.Sender ?? "—")</span></div>
        <div class="kv"><span>To</span><span>@_message.Recipient@(_message.JunkedAt is not null ? _message.JunkManual ? " (in Junk, manual)" : " (in Junk)" : "")</span></div>
        <div class="kv"><span>Received</span><span>@_message.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></div>
        @if (_message.ParseError is not null)
        {
            <div class="kv"><span>Parse error</span><span class="error">@_message.ParseError</span></div>
        }
        <div class="kv">
            <span>Actions</span>
            <span class="msg-action-btns">
                @if (_message.JunkedAt is null)
                {
                    <button class="btn-sm btn-ghost" @onclick="MoveToJunkAsync" disabled="@_busy">Move to Junk</button>
                }
                else
                {
                    <button class="btn-sm btn-ghost" @onclick="UnjunkAsync" disabled="@_busy">Unjunk</button>
                }
                @if (_confirmingDelete)
                {
                    <span class="muted">Delete permanently?</span>
                    <button class="btn-sm btn-ghost danger" @onclick="DeleteAsync" disabled="@_busy">Yes</button>
                    <button class="btn-sm btn-ghost" @onclick="() => _confirmingDelete = false" disabled="@_busy">No</button>
                }
                else
                {
                    <button class="btn-sm btn-ghost danger" @onclick="() => _confirmingDelete = true" disabled="@_busy">Delete</button>
                }
                @if (!string.IsNullOrWhiteSpace(_message.Sender))
                {
                    <button class="btn-sm btn-ghost" @onclick="() => BlockNavigate(RuleTarget.Sender, _message.Sender!)">Block sender</button>
                }
                @if (IsCatchAll)
                {
                    <button class="btn-sm btn-ghost" @onclick="() => BlockNavigate(RuleTarget.Recipient, _message.Recipient)">Block recipient</button>
                    <button class="btn-sm btn-ghost" @onclick="CreateAliasNavigate">Create alias</button>
                }
                <button class="btn-sm btn-ghost" @onclick="ToggleHeadersAsync" disabled="@_busy">@(_showHeaders ? "Hide headers" : "View headers")</button>
                <a class="btn-sm btn-ghost" href="@($"api/messages/{_message.Id}/raw")" target="_blank">Download .eml</a>
            </span>
        </div>
        @if (_showHeaders)
        {
            <div class="panel headers-panel">
                <h3 class="msg-section">Headers</h3>
                <pre class="text-view">@(_headers ?? "Loading…")</pre>
            </div>
        }
    </div>

    @if (_attachments is { Count: > 0 })
    {
        <div class="panel att-panel">
            <h3 class="msg-section">Attachments (@_attachments.Count)</h3>
            <ul class="att-list">
                @foreach (var a in _attachments)
                {
                    <li>
                        <a href="@($"api/attachments/{a.Id}/content")" target="_blank">@(a.Filename ?? $"attachment-{a.Id}")</a>
                        <span class="muted">(@(a.ContentType ?? "?"), @(a.SizeBytes?.ToString() ?? "?") bytes)</span>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="msg-bodywrap">
        <div class="body-toolbar">
            @if (HasHtml)
            {
                <label class="switch" title="Switch between plain text and HTML">
                    <input type="checkbox" checked="@_showHtml" @onchange="() => _showHtml = !_showHtml" />
                    <span class="slider"></span>
                    <span class="switch-label">@(_showHtml ? "HTML" : "Text")</span>
                </label>
                <span class="muted body-note">
                    @(_showHtml ? "Remote images, scripts and fonts are blocked." : "Plain text shown by default for safety.")
                </span>
            }
            else
            {
                <span class="muted body-note">Plain text</span>
            }
        </div>

        @if (_showHtml && HasHtml)
        {
            @* Untrusted HTML: sandbox="" blocks scripts/forms; the injected CSP blocks remote loads. *@
            <iframe class="html-view" sandbox="" srcdoc="@HtmlSrcDoc"></iframe>
        }
        else
        {
            <pre class="text-view"><LinkifiedText Text="@_body?.TextBody" Empty="@(_message.Parsed ? "(no text body)" : "(still processing…)")" /></pre>
        }
    </div>
}

@code {
    [Parameter] public long MessageId { get; set; }

    /// <summary>True when viewed inside the catch-all inbox; enables the "Block recipient" button.</summary>
    [Parameter] public bool IsCatchAll { get; set; }

    /// <summary>Raised after a junk/unjunk so the parent list can refresh.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private Message? _message;
    private MessageBody? _body;
    private IReadOnlyList<Attachment>? _attachments;
    private bool _loaded;
    private bool _showHtml;
    private bool _busy;
    private bool _confirmingDelete;
    private bool _showHeaders;
    private string? _headers;
    private long _loadedId = -1;

    private const string ContentSecurityPolicy =
        "default-src 'none'; img-src data:; style-src 'unsafe-inline'; font-src data:; base-uri 'none'; form-action 'none'";

    private bool HasHtml => !string.IsNullOrEmpty(_body?.HtmlBody);

    private string HtmlSrcDoc =>
        $"<meta http-equiv=\"Content-Security-Policy\" content=\"{ContentSecurityPolicy}\">{_body?.HtmlBody}";

    protected override async Task OnParametersSetAsync()
    {
        if (MessageId == _loadedId) return; // only reload when the selected message changes
        _loadedId = MessageId;
        _showHtml = false;
        _confirmingDelete = false;
        _showHeaders = false;
        _headers = null;
        _loaded = false;
        _message = await Messages.GetByIdAsync(MessageId);
        if (_message is not null)
        {
            _body = await Messages.GetBodyAsync(MessageId);
            _attachments = await Messages.ListAttachmentsAsync(MessageId);
        }
        else
        {
            _body = null;
            _attachments = null;
        }
        _loaded = true;
        StartParsePolling();
    }

    // The background worker parses MIME asynchronously, so a just-received message can load with
    // Parsed = false. Poll until it's parsed, then refresh this reader and the parent list (badge).
    private CancellationTokenSource? _parseCts;

    private void StartParsePolling()
    {
        _parseCts?.Cancel();
        _parseCts?.Dispose();
        _parseCts = null;
        if (_message is { Parsed: false })
        {
            _parseCts = new CancellationTokenSource();
            _ = PollUntilParsedAsync(_message.Id, _parseCts.Token);
        }
    }

    private async Task PollUntilParsedAsync(long id, CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
            var attempts = 0;
            while (attempts++ < 60 && await timer.WaitForNextTickAsync(ct))
            {
                if (id != _loadedId) return; // selection changed
                var msg = await Messages.GetByIdAsync(id, ct);
                if (msg is null) return;
                if (msg.Parsed)
                {
                    _message = msg;
                    _body = await Messages.GetBodyAsync(id, ct);
                    _attachments = await Messages.ListAttachmentsAsync(id, ct);
                    await InvokeAsync(StateHasChanged);
                    await OnChanged.InvokeAsync(); // refresh the parent list (clears the "unparsed" badge)
                    return;
                }
            }
        }
        catch (OperationCanceledException) { /* selection changed or component disposed */ }
    }

    public void Dispose()
    {
        _parseCts?.Cancel();
        _parseCts?.Dispose();
    }

    private void BlockNavigate(RuleTarget target, string value)
    {
        var t = target == RuleTarget.Sender ? "sender" : "recipient";
        Nav.NavigateTo($"rules?target={t}&pattern={Uri.EscapeDataString(value)}&match=literal&action=junk");
    }

    private void CreateAliasNavigate()
    {
        if (_message is null) return;
        Nav.NavigateTo($"aliases?new={Uri.EscapeDataString(_message.Recipient)}&notes={Uri.EscapeDataString("(Quick Alias)")}");
    }

    private async Task ToggleHeadersAsync()
    {
        _showHeaders = !_showHeaders;
        if (_showHeaders && _headers is null)
            _headers = await LoadHeadersAsync();
    }

    // Read the raw MIME header block (everything before the first blank line) from the raw store.
    private async Task<string> LoadHeadersAsync()
    {
        if (string.IsNullOrEmpty(_message?.RawStoragePath))
            return "(no raw source available)";
        try
        {
            await using var stream = await RawStore.OpenReadAsync(_message.RawStoragePath);
            var buffer = new byte[64 * 1024]; // headers are small; read the first chunk only
            var read = await stream.ReadAtLeastAsync(buffer, buffer.Length, throwOnEndOfStream: false);
            var text = System.Text.Encoding.UTF8.GetString(buffer, 0, read);
            var end = text.IndexOf("\r\n\r\n", StringComparison.Ordinal);
            if (end < 0) end = text.IndexOf("\n\n", StringComparison.Ordinal);
            return (end >= 0 ? text[..end] : text).Trim();
        }
        catch (Exception ex)
        {
            return $"(could not read headers: {ex.Message})";
        }
    }

    private async Task DeleteAsync()
    {
        if (_message is null) return;
        _busy = true;
        try
        {
            await Messages.DeleteAsync(_message.Id);
            await Audit.WriteAsync(new AuditEntry { Action = "message.delete", TargetType = "message", TargetId = _message.Id.ToString(), Actor = "ui", CreatedAt = DateTimeOffset.UtcNow });
            _confirmingDelete = false;
            await OnChanged.InvokeAsync();
        }
        finally { _busy = false; }
    }

    private async Task MoveToJunkAsync()
    {
        if (_message is null) return;
        _busy = true;
        try
        {
            await Blacklist.JunkMessageAsync(_message.Id);
            await OnChanged.InvokeAsync();
        }
        finally { _busy = false; }
    }

    private async Task UnjunkAsync()
    {
        if (_message is null) return;
        _busy = true;
        try
        {
            await Blacklist.UnjunkMessageAsync(_message.Id);
            await OnChanged.InvokeAsync();
        }
        finally { _busy = false; }
    }
}
