<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="fonts.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="icon" href="data:," />
    <title>Inbix</title>
    <HeadOutlet />
</head>
<body>
    <Routes />

    @* Blazor toggles the components-reconnect-* classes on this element by connection state. *@
    <div id="components-reconnect-modal">
        <div class="reconnect-dialog">
            <div class="reconnect-spinner" aria-hidden="true"></div>
            <p class="reconnect-line reconnect-reconnecting">Reconnecting to the server&hellip;</p>
            <p class="reconnect-line reconnect-failed">
                Connection lost. <a href="" class="reload">Reload</a>
            </p>
            <p class="reconnect-line reconnect-rejected">
                The server connection was lost. <a href="" class="reload">Reload</a>
            </p>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
</body>
</html>
