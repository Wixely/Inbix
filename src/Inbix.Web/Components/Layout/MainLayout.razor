@inherits LayoutComponentBase

<div class="layout">
    @* Pure-CSS drawer toggle: the hamburger label flips this checkbox; CSS slides the sidebar in. *@
    <input type="checkbox" id="nav-toggle" class="nav-toggle" autocomplete="off" />
    <header class="topbar">
        <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
        </label>
        <span class="brand-name">Inbix</span>
    </header>
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 5h16v14H4z" />
                    <path d="M4 7l8 6 8-6" />
                </svg>
            </span>
            <span class="brand-name">Inbix</span>
        </div>
        <NavMenu @rendermode="InteractiveServer" />
        <div class="sidebar-foot">
            <AuthorizeView>
                <Authorized>
                    <div class="signed-in">
                        <span class="muted">Signed in as</span> <strong>@context.User.Identity?.Name</strong>
                        <form method="post" action="auth/logout" class="logout-form">
                            <button type="submit" class="btn-link">Sign out</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
            <SidebarStatus @rendermode="InteractiveServer" />
        </div>
    </aside>
    <label for="nav-toggle" class="nav-backdrop" aria-hidden="true"></label>
    <main class="content">
        @Body
    </main>
</div>
