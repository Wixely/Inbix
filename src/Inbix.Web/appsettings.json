{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Inbix": {
    "Domains": [ "mydomain.com" ],
    "RequireHttps": false,
    "Database": {
      "Provider": "sqlite",
      "ConnectionString": "Data Source=./data/inbix.db",
      "MigrateOnStartup": true
    },
    "Smtp": {
      "Port": 25,
      "ServerName": "inbix",
      "MaxMessageSizeBytes": 26214400,
      "MaxConcurrentSessions": 50,
      "MaxConnectionsPerMinutePerIp": 0,
      "CertificatePath": "",
      "CertificatePassword": ""
    },
    "Storage": {
      "RawPath": "./data/raw"
    },
    "Worker": {
      "PollSeconds": 5,
      "BatchSize": 20
    },
    "Backups": {
      "Enabled": false,
      "Directory": "./data/backups",
      "IntervalHours": 24,
      "RetentionCount": 7
    },
    "Admin": {
      "Username": "admin",
      "Password": "",
      "PasswordHash": "",
      "ApiKey": ""
    },
    "Diagnostics": {
      "PublicIpLookupUrl": "https://checkip.amazonaws.com"
    }
  }
}
