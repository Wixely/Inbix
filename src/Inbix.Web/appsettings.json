{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Inbix": {
    "Domains": [ "mydomain.com" ],
    "Database": {
      "Provider": "sqlite",
      "ConnectionString": "Data Source=./data/inbix.db",
      "MigrateOnStartup": true
    },
    "Smtp": {
      "Port": 25,
      "ServerName": "inbix",
      "MaxMessageSizeBytes": 26214400,
      "MaxConcurrentSessions": 50,
      "CertificatePath": "",
      "CertificatePassword": ""
    },
    "Storage": {
      "RawPath": "./data/raw"
    },
    "Worker": {
      "PollSeconds": 5,
      "BatchSize": 20
    },
    "Admin": {
      "ApiKey": ""
    }
  }
}
