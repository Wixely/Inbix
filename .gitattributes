# Normalise line endings: store text as LF in the repo, check out native on each OS.
* text=auto eol=lf

# Windows-centric scripts stay CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Treat known binaries as binary.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pfx binary
*.db binary
